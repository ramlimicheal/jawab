# Database
DATABASE_URL="postgresql://user:password@localhost:5432/jawab?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI Provider (gemini, groq, or openai - auto-detected from which API key is set)
AI_PROVIDER=""
OPENAI_API_KEY=""
GROQ_API_KEY=""
GEMINI_API_KEY=""

# Website Scraping (Firecrawl for JS rendering + anti-bot, falls back to Cheerio if not set)
FIRECRAWL_API_KEY=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Email (for password reset & email verification — set up SendGrid, Resend, or similar)
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASSWORD=""
# EMAIL_FROM="noreply@jawab.ai"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
